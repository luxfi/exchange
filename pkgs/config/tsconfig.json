{
  "extends": "../../config/tsconfig/app.json",
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.json",
    "env.native.d.ts",
    "env.d.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ],
  "compilerOptions": {
    "emitDeclarationOnly": true,
    "noEmit": false,
    "types": ["node"],
    "paths": {
      "@l.x/config/*": ["./src/*"]
    }
  },
  "references": [
    {
      "path": "../utilities"
    },
    {
      "path": "../eslint-config"
    }
  ]
}
