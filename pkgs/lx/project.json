{
  "tags": ["scope:lux", "type:lib"],
  "targets": {
    "prepare": {
      "executor": "nx:noop",
      "dependsOn": ["contracts"],
      "cache": true,
      "inputs": [],
      "outputs": []
    },
    "build": {
      "command": "tsc -b",
      "options": {
        "cwd": "{projectRoot}"
      },
      "dependsOn": ["prepare", "^build", "contracts", "graphql:generate"]
    },
    "contracts:compile:abi": {
      "command": "test -f src/abis/types/index.ts && echo 'abi types exist' || typechain --target ethers-v5 --out-dir src/abis/types \"./src/abis/**/*.json\"",
      "options": {
        "cwd": "{projectRoot}"
      },
      "cache": true,
      "inputs": ["{projectRoot}/src/abis/**/*.json", "!{projectRoot}/src/abis/types/**"],
      "outputs": ["{projectRoot}/src/abis/types/*.ts", "{projectRoot}/src/abis/types/factories"]
    },
    "contracts:compile:v3": {
      "command": "test -f src/abis/types/v3/index.ts && echo 'v3 types exist' || (ls ../../node_modules/@lux/**/artifacts/contracts/**/*.json >/dev/null 2>&1 && typechain --target ethers-v5 --out-dir src/abis/types/v3 \"../../node_modules/@lux/**/artifacts/contracts/**/*[!dbg].json\" || (mkdir -p src/abis/types/v3 && echo 'export {}' > src/abis/types/v3/index.ts && echo 'v3 types stub created'))",
      "options": {
        "cwd": "{projectRoot}"
      },
      "cache": true,
      "inputs": ["{projectRoot}/package.json"],
      "outputs": ["{projectRoot}/src/abis/types/v3/**"]
    },
    "contracts": {
      "command": "echo \"Compiling contracts...\"",
      "options": {
        "cwd": "{projectRoot}"
      },
      "cache": true,
      "dependsOn": ["contracts:compile:abi", "contracts:compile:v3"]
    },
    "check:deps:usage": {},
    "typecheck": {},
    "typecheck:tsgo": {},
    "lint:biome": {},
    "lint:biome:fix": {},
    "lint:eslint": {},
    "lint:eslint:fix": {},
    "lint": {},
    "lint:fix": {},
    "test": {
      "command": "vitest run",
      "options": {
        "cwd": "{projectRoot}"
      }
    },
    "snapshots": {
      "command": "vitest run -u",
      "options": {
        "cwd": "{projectRoot}"
      }
    }
  }
}
