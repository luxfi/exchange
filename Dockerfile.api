# Exchange API Backend Dockerfile
FROM node:22-alpine

WORKDIR /app

# Install only the dependencies server.js needs
RUN npm install express cors ethers helmet express-rate-limit

# Copy server
COPY server.js .

# Create non-root user
RUN addgroup -g 1001 -S nodejs && \
    adduser -S nodejs -u 1001

USER nodejs

EXPOSE 4000

CMD ["node", "server.js"]
