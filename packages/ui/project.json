{
  "tags": ["scope:ui", "type:lib"],
  "targets": {
    "build": {
      "dependsOn": ["^build", "build:icons"]
    },
    "build:icons": {
      "command": "bunx tsx ./src/scripts/componentize-icons.ts && nx run ui:format:generated",
      "options": {
        "cwd": "{projectRoot}"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/scripts/componentize-icons.ts",
        "{projectRoot}/src/assets/icons/**",
        "{projectRoot}/src/assets/logos/**"
      ],
      "outputs": ["{projectRoot}/src/components/icons/**", "{projectRoot}/src/components/logos/**"]
    },
    "build:icons:missing": {
      "command": "bunx tsx ./src/scripts/componentize-icons.ts --skip-existing && nx run ui:format:generated",
      "options": {
        "cwd": "{projectRoot}"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/scripts/componentize-icons.ts",
        "{projectRoot}/src/assets/icons/**",
        "{projectRoot}/src/assets/logos/**"
      ],
      "outputs": ["{projectRoot}/src/components/icons/**", "{projectRoot}/src/components/logos/**"]
    },
    "check:deps:usage": {},
    "typecheck": {
      "dependsOn": ["build:icons", "^typecheck"]
    },
    "typecheck:tsgo": {
      "dependsOn": ["build:icons"]
    },
    "lint:eslint": {},
    "lint:eslint:fix": {},
    "lint": {},
    "lint:fix": {},
    "check": {},
    "check:fix": {},
    "test": {
      "command": "vitest run",
      "options": {
        "cwd": "{projectRoot}"
      }
    },
    "watch": {
      "command": "bun run build --watch",
      "options": {
        "cwd": "{projectRoot}"
      }
    },
    "format:generated": {
      "command": "for i in 1 2 3; do oxlint --fix --fix-suggestions --fix-dangerously -D sort-imports --threads=1 src/components/icons src/components/logos 2>/dev/null; done; oxfmt --threads=4 src/components/icons src/components/logos",
      "options": {
        "cwd": "{projectRoot}"
      },
      "cache": false
    },
    "oxfmt": {},
    "oxfmt:fix": {},
    "oxlint": {},
    "oxlint:fix": {},
    "oxlint:type-aware": {}
  }
}
