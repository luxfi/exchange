ignores: [
    # Dependencies that depcheck thinks are unused but are actually used
    "ethers",
    "@typechain/ethers-v5",
    "jest-presets",
    "depcheck",
    "typescript",
    "eslint",
    "@typescript/native-preview",
    "typechain",
    "tamagui",
    "@shopify/react-native-skia",
    # Dependencies that depcheck thinks are missing but are actually present or never used
    ## Internal packages / workspaces
    "uniswap",
    "utilities",
    "src",
    "tsconfig",
    "config",
    ## GraphQL
    "@graphql-codegen/*",
    # i18n
    "i18next-resources-for-ts",
    # Crypto deps used via deep imports (@noble/hashes/sha2.js, etc.)
    "@noble/*",
    "@cloudflare/*",
    # zustand store dev tooling
    "@redux-devtools/extension",
  ]
