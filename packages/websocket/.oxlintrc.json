{
  "extends": ["../../.oxlintrc.json"],
  "rules": {
    "universe-custom/no-relative-import-paths": [
      "error",
      {
        "allowSameFolder": false,
        "prefix": "@universe/websocket"
      }
    ]
  },
  "overrides": [
    {
      "files": ["**/*"],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ]
}
