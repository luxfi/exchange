{
  "tags": ["scope:eslint-config", "type:tooling"],
  "targets": {
    "lint:eslint": {
      "command": "eslint . --max-warnings=0"
    },
    "lint:eslint:fix": {
      "command": "eslint . --fix"
    },
    "lint": {},
    "lint:fix": {},
    "check": {},
    "check:fix": {},
    "test": {
      "command": "jest",
      "options": {
        "cwd": "{projectRoot}"
      }
    },
    "oxfmt": {},
    "oxfmt:fix": {},
    "oxlint": {},
    "oxlint:fix": {},
    "oxlint:type-aware": {}
  }
}
