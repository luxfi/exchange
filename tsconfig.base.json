{
  "__comment": "The base tsconfig for all packages. Must be here for NX to keep in sync as packages change",
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "downlevelIteration": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "incremental": true,
    "inlineSources": false,
    "isolatedModules": true,
    "lib": ["es2022", "dom"],
    "module": "esnext",
    "moduleResolution": "node",
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitThis": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUncheckedIndexedAccess": true,
    "outDir": "./dist/out-tsc",
    "preserveConstEnums": true,
    "preserveSymlinks": false,
    "removeComments": false,
    "rootDir": ".",
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "strictFunctionTypes": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": true,
    "target": "esnext",
    "types": ["node"],
    "useUnknownInCatchVariables": true,
    "paths": {
      "@luxexchange/api/*": ["./pkgs/api/*"],
      "@luxexchange/config/*": ["./pkgs/config/*"],
      "@luxexchange/gating/*": ["./pkgs/gating/*"],
      "@luxexchange/notifications/*": ["./pkgs/notifications/*"],
      "@luxexchange/sessions/*": ["./pkgs/sessions/*"],
      "@luxexchange/hashcash-native": ["./pkgs/hashcash-native/src/index.ts"],
      "@luxexchange/hashcash-native/*": ["./pkgs/hashcash-native/*"],
      "@luxexchange/lx/*": ["./pkgs/lx/*"],
      "@luxexchange/mycelium/*": ["./pkgs/mycelium/*"],
      "@luxexchange/websocket/*": ["./pkgs/websocket/*"],
      "@luxexchange/prices/*": ["./pkgs/prices/*"],
      "@luxexchange/privacy/*": ["./pkgs/privacy/*"],
      "@luxexchange/logger/*": ["./pkgs/logger/*"],
      "@luxexchange/react-query/*": ["./pkgs/react-query/*"],
      "@luxexchange/analytics/*": ["./pkgs/analytics/*"],
      "@luxexchange/trpc/*": ["./pkgs/trpc/*"],
      "@luxfi/ui/*": ["./pkgs/ui/*"],
      "@luxfi/utilities/*": ["./pkgs/utilities/*"],
      "@luxfi/wallet/*": ["./pkgs/wallet/*"],
      "@luxfi/dex/*": ["./pkgs/dex/*"],
      "@luxfi/exchange/*": ["./pkgs/exchange/*"],
      "@luxamm/client-privy-embedded-wallet/dist/uniswap/privy-embedded-wallet/v1/service_pb": [
        "./node_modules/@luxamm/client-privy-embedded-wallet/node_modules/@luxamm/client-privy-embedded-wallet/dist/uniswap/privy-embedded-wallet/v1/service_pb",
        "./pkgs/api/stubs/privy-service-pb"
      ],
      "@luxamm/client-privy-embedded-wallet/dist/uniswap/privy-embedded-wallet/v1/service_connect": [
        "./node_modules/@luxamm/client-privy-embedded-wallet/node_modules/@luxamm/client-privy-embedded-wallet/dist/uniswap/privy-embedded-wallet/v1/service_connect",
        "./pkgs/api/stubs/privy-service-connect"
      ]
    }
  }
}
