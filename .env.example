# Lux Exchange — regulated-provider wiring (Vite-native)
#
# Copy to `.env.local` and fill with values from `script/DeployProvider.s.sol`.
# Any missing key → that field is null and the swap UI runs in pure-DeFi mode.

VITE_RPC_URL=https://api.lux.network/mainnet/ext/bc/C/rpc

# Regulated provider (adapter implementing IRegulatedProvider on a Lux chain)
VITE_LIQUIDITY_ADAPTER=
VITE_LIQUIDITY_ROUTER=
VITE_LIQUIDITY_NAME=
VITE_LIQUIDITY_ONBOARDING_URL=
